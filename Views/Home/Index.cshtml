@model CargadorHorario.Web.Models.CargaHorarioViewModel

@{
    ViewData["Title"] = "Cargador horario semanal";
    var diasSemana = new[] { "L", "M", "X", "J", "V", "S", "D" };
    var primerDia = new DateTime(Model.Anio, Model.Mes, 1);
    var diasEnMes = DateTime.DaysInMonth(Model.Anio, Model.Mes);
    var primerDiaSemana = ((int)primerDia.DayOfWeek + 6) % 7; // Lunes = 0
}

<div class="container-fluid">
    <div class="ventana-principal">
        <div class="barra-titulo">
            <span class="icono-ventana">⚙</span>
            <span class="titulo-ventana">Cargador horario semanal</span>
        </div>

        <div class="contenido-ventana">
            <!-- Mensaje de estado -->
            <div class="mensaje-estado @(Model.EsError ? "error" : "")">
                @Model.Mensaje
            </div>

            <form asp-action="Generar" method="post">
                <!-- Tipo de Carga -->
                <div class="seccion-tipo-carga">
                    <fieldset>
                        <legend>Tipo de Carga</legend>
                        <div class="radio-group">
                            <label>
                                <input type="radio" name="TipoCarga" value="1" checked="@(Model.TipoCarga == TiposCarga.Coordinadora)" />
                                COORDINADORA
                            </label>
                            <label>
                                <input type="radio" name="TipoCarga" value="2" checked="@(Model.TipoCarga == TiposCarga.Distrito)" />
                                DISTRITO
                            </label>
                            <label>
                                <input type="radio" name="TipoCarga" value="3" checked="@(Model.TipoCarga == TiposCarga.Todos)" />
                                TODOS
                            </label>
                        </div>
                    </fieldset>
                </div>

                <!-- Financiación y Código Programa -->
                <div class="seccion-financiacion">
                    <label>FINANCIACIÓN</label>
                    <select name="FinanciacionSeleccionada" class="combo-financiacion">
                        <option value=""></option>
                        @foreach (var financiacion in Model.Financiaciones)
                        {
                            var isSelected = Model.FinanciacionSeleccionada == financiacion.Codigo;
                            <option value="@financiacion.Codigo" selected="@isSelected">
                                @financiacion.Nombre
                            </option>
                        }
                    </select>

                    <label>CodPrograma</label>
                    <input type="text" name="CodPrograma" value="@Model.CodPrograma" class="input-codprograma" />
                </div>

                <!-- Parámetros de carga -->
                <div class="seccion-parametros">
                    <fieldset>
                        <legend>Parámetros de carga</legend>
                        
                        <div class="parametros-contenido">
                            <!-- Calendario -->
                            <div class="calendario-container">
                                <div class="calendario-header">
                                    <button type="button" class="btn-mes" onclick="cambiarMes(-1)">◄</button>
                                    <span class="mes-actual" id="mesActual">@(new DateTime(Model.Anio, Model.Mes, 1).ToString("MMMM yyyy", new System.Globalization.CultureInfo("es-ES")))</span>
                                    <button type="button" class="btn-mes" onclick="cambiarMes(1)">►</button>
                                </div>
                                
                                <table class="calendario">
                                    <thead>
                                        <tr>
                                            @foreach (var dia in diasSemana)
                                            {
                                                <th>@dia</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{
                                            var diaActual = 1;
                                            var semanas = (int)Math.Ceiling((diasEnMes + primerDiaSemana) / 7.0);
                                        }
                                        @for (int semana = 0; semana < semanas; semana++)
                                        {
                                            <tr>
                                                @for (int diaSemana = 0; diaSemana < 7; diaSemana++)
                                                {
                                                    @if ((semana == 0 && diaSemana < primerDiaSemana) || diaActual > diasEnMes)
                                                    {
                                                        <td class="dia-vacio"></td>
                                                    }
                                                    else
                                                    {
                                                        var fecha = new DateTime(Model.Anio, Model.Mes, diaActual);
                                                        var esHoy = fecha.Date == DateTime.Now.Date;
                                                        <td class="dia @(esHoy ? "dia-hoy" : "")" data-dia="@diaActual">@diaActual</td>
                                                        diaActual++;
                                                    }
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>

                                <div class="fecha-hoy">
                                    <strong>Hoy: @DateTime.Now.ToString("dd/MM/yyyy")</strong>
                                </div>

                                <input type="hidden" name="Mes" value="@Model.Mes" id="mesHidden" />
                                <input type="hidden" name="Anio" value="@Model.Anio" id="anioHidden" />
                            </div>

                            <!-- Campos de parámetros -->
                            <div class="campos-parametros">
                                <div class="campo-grupo">
                                    <label>Año</label>
                                    <input type="number" name="Anio" value="@Model.Anio" class="input-anio" min="2000" max="2099" />
                                </div>

                                <div class="campo-grupo">
                                    <label>NumSemana<br/>general</label>
                                    <input type="number" name="NumSemanaGeneral" value="@Model.NumSemanaGeneral" class="input-numero" />
                                </div>

                                <div class="campo-grupo">
                                    <label>1er día semana<br/>general</label>
                                    <input type="number" name="PrimerDiaSemanaGeneral" value="@Model.PrimerDiaSemanaGeneral" class="input-numero" />
                                </div>

                                <div class="campo-grupo">
                                    <label>Nº semanas a<br/>generar (mín 1)</label>
                                    <input type="number" name="NumSemanasAGenerar" value="@Model.NumSemanasAGenerar" class="input-numero" min="1" />
                                </div>

                                <div class="campo-grupo">
                                    <label>(**) Día</label>
                                    <input type="text" name="FechaDia" value="@Model.FechaDia" class="input-fecha" placeholder="__/__/____" />
                                </div>
                            </div>
                        </div>

                        <!-- Expresión Auxiliar -->
                        <div class="expresion-auxiliar">
                            <label>(*) ExpAuxiliar</label>
                            <input type="text" name="ExpAuxiliar" value="@Model.ExpAuxiliar" class="input-exp" />
                        </div>

                        <!-- Nota -->
                        <div class="nota">
                            (*) Usado para cargar la plantilla de una única auxiliar
                        </div>

                        <!-- Checkboxes -->
                        <div class="checkboxes">
                            <label>
                                <input type="checkbox" name="ActualizarTablaDiaSemana" checked="@Model.ActualizarTablaDiaSemana" />
                                Actualizar tabla TBL_DiaSemana
                            </label>
                            <label>
                                <input type="checkbox" name="ProyeccionSeparada" checked="@Model.ProyeccionSeparada" />
                                Proyección separada
                            </label>
                        </div>
                    </fieldset>
                </div>

                <!-- Botones -->
                <div class="botones-accion">
                    <button type="submit" class="btn-generar">GENERAR</button>
                    <button type="button" class="btn-salir" onclick="window.location.href='@Url.Action("Salir")'">SALIR</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let mesActual = @Model.Mes;
        let anioActual = @Model.Anio;

        function cambiarMes(delta) {
            mesActual += delta;
            if (mesActual > 12) {
                mesActual = 1;
                anioActual++;
            } else if (mesActual < 1) {
                mesActual = 12;
                anioActual--;
            }
            
            document.getElementById('mesHidden').value = mesActual;
            document.getElementById('anioHidden').value = anioActual;
            
            // Recargar la página con el nuevo mes
            window.location.href = '?mes=' + mesActual + '&anio=' + anioActual;
        }

        // Permitir seleccionar días del calendario
        document.querySelectorAll('.dia:not(.dia-vacio)').forEach(function(celda) {
            celda.addEventListener('click', function() {
                document.querySelectorAll('.dia').forEach(d => d.classList.remove('seleccionado'));
                this.classList.add('seleccionado');
            });
        });
    </script>
}
